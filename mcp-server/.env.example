# Supabase project (Settings -> API Keys)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SECRET_KEY=YOUR-SB-SECRET-KEY

# Required: shared secret OpenClaw will pass to authenticate
# Use a long random string. The MCP URL becomes:
#   https://your-mcp.onrender.com/sse?key=<MCP_API_KEY>
MCP_API_KEY=replace-with-a-long-random-string

# Server config
PORT=8081
