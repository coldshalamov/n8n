# Copy this to .env.local and fill in values from your Supabase project
# (Settings → API → URL and anon/public key)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Service role key (Settings → API → service_role)
# REQUIRED for the contractor portal magic-link auto-link flow.
# Server-only — never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Public n8n editor URL. Used for the wrapper's "Open n8n" launch links.
NEXT_PUBLIC_N8N_URL=https://YOUR-N8N-SERVICE.onrender.com
